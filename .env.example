# 湯マップ 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定してください
# cp .env.example .env

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Maps
GOOGLE_MAPS_KEY_ANDROID=your_android_maps_key
GOOGLE_MAPS_KEY_IOS=your_ios_maps_key

# RevenueCat
REVENUECAT_KEY_ANDROID=your_revenuecat_android_key
REVENUECAT_KEY_IOS=your_revenuecat_ios_key

# AdMob
ADMOB_BANNER_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
ADMOB_BANNER_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
ADMOB_REWARDED_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
ADMOB_REWARDED_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx

# Sentry
SENTRY_DSN=https://your_sentry_dsn_here
