<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.yumap.app">

    <!-- 🔐 必要な権限設定 -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.CAMERA"/>
    <!-- Android 12以下でフォトライブラリにアクセスするために必要。
         Android 13以上はシステムの photo picker を使うため不要（maxSdkVersion="32"） -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <!-- 📱 ハードウェア要件（Google Playでのフィルタリング用） -->
    <uses-feature android:name="android.hardware.camera" android:required="false"/>
    <uses-feature android:name="android.hardware.location.gps" android:required="false"/>
    <uses-feature android:name="android.hardware.location.network" android:required="false"/>

    <application
        android:label="湯マップ"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <!-- 🗺️ Google Maps API Key 設定 -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyA4e_UqLkMEKcIM9i0SyW7LjjyyaMh-FEg" />

        <!-- 📢 Google AdMob 設定（テスト用ID） -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713"/>

        <!-- 広告設定の競合回避 -->
        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <!-- 📱 メインアクティビティ設定 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme" />
            
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- 🔗 Deep Linking: カスタムURLスキーム yumap:// -->
            <!-- 例: yumap://facility/abc-123 でアプリを起動して施設詳細へ遷移する -->
            <intent-filter android:label="湯マップ">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="yumap"/>
            </intent-filter>

            <!-- 🔗 App Links: https://yumap.app のURLでアプリを開く（要 assetlinks.json 設置）-->
            <!-- 将来対応: yumap.app のウェブサーバーに
                 /.well-known/assetlinks.json を配置することで有効になる -->
            <intent-filter android:autoVerify="true" android:label="湯マップ">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="yumap.app"/>
            </intent-filter>
        </activity>
        
        <!-- Flutter Embedding v2 -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
</manifest>