# Yu-Map Environment Configuration
# Copy to .env and fill in real values before building.
# Pass to Flutter via --dart-define-from-file=.env

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# Google Maps
GOOGLE_MAPS_KEY_ANDROID=
GOOGLE_MAPS_KEY_IOS=

# RevenueCat (subscriptions)
REVENUECAT_KEY_ANDROID=
REVENUECAT_KEY_IOS=

# AdMob (leave blank to use test IDs)
ADMOB_BANNER_ANDROID=
ADMOB_BANNER_IOS=
ADMOB_REWARDED_ANDROID=
ADMOB_REWARDED_IOS=

# Sentry (error tracking)
SENTRY_DSN=
